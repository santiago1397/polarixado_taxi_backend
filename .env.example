PORT=4000
FRONTEND_URL=http://localhost:5173
PUBLIC_URL=http://localhost:5173
API_URL=http://localhost:4000

JWT_SECRET=your-256-bit-secret

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=your-password
SEED_ADMIN_NAME=Super Admin

DRIVER_EMAIL=driver@example.com
DRIVER_NAME=Tio Nen

ZELLE_HANDLE=your-zelle@example.com
ZELLE_NAME=Tio Nen

BASE_FARE=5
PER_KM=2
CURRENCY=USD

# SendGrid SMTP — create an API key with "Mail Send" permission
SENDGRID_API_KEY=SG.xxxxxxxx
MAIL_FROM="Tio Nen Taxi" <no-reply@example.com>

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Twilio SMS — get credentials at https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+15555550123
DEFAULT_SMS_COUNTRY_CODE=+1

# WhatsApp Business API (Meta Cloud API)
# Phone Number ID and permanent access token from Meta Business Manager
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# Base URL used to build driver confirmation links in WhatsApp messages
APP_URL=https://yourdomain.com
