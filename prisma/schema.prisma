generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TripMode {
  ASAP
  SCHEDULED
}

enum VehicleType {
  UBER_X
  UBER_COMFORT
  UBER_XL
  UBER_XXL
  BLACK_CAR
}

enum TripState {
  PENDING_PAYMENT
  CONFIRMED
  EN_ROUTE
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  STRIPE
  ZELLE
  CASH
  ZELLE_LATER
  CASHAPP
}

enum PaymentTiming {
  NOW
  LATER
}

enum PaymentStatus {
  PENDING
  PENDING_VERIFICATION
  PAID
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

enum ConsentMethod {
  BROWSEWRAP_CLICK
  EXPLICIT_CHECKBOX
  ADMIN_OVERRIDE
}

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Deal {
  id             String      @id @default(cuid())
  title          String
  description    String?
  imageUrl       String?
  destination    String
  destLat        Float
  destLng        Float
  price          Float
  currency       String      @default("USD")
  passengerCount Int
  departureAt    DateTime
  returnAt       DateTime
  vehicleType    VehicleType @default(UBER_XL)
  active         Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Driver {
  id           String   @id @default(cuid())
  name         String
  phone        String   @unique
  email        String?
  vehicleMake  String
  vehicleColor String
  vehiclePlate String
  vehicleYear  Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  trips        Trip[]
}

model ConsentLog {
  id          String        @id @default(cuid())
  tripId      String
  trip        Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  channels    String[]
  consentedAt DateTime      @default(now())
  method      ConsentMethod
  textVersion String
  ip          String?
  userAgent   String?
  createdAt   DateTime      @default(now())

  @@index([tripId])
}

model Config {
  id                  String   @id @default("singleton")
  vehicleTiers        Json
  currency            String   @default("USD")
  zelleHandle         String?
  zelleName           String?
  namedPlaces         Json?    @default("null")
  zones               Json?    @default("null")
  timeOfDaySurcharge  Json?    @default("null")
  tollRoads              Json?    @default("null")
  crossingRules          Json?    @default("null")
  whatsappEnabled        Boolean  @default(false)
  whatsappRecipientPhone String?
  whatsappRecipientName  String?
  updatedAt              DateTime @updatedAt
}

model Trip {
  id              String        @id
  groupId         String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  vehicleType     VehicleType   @default(UBER_X)
  mode            TripMode
  scheduledAt     DateTime?
  customerName    String
  customerEmail   String
  customerPhone   String?
  originAddress   String
  originLat       Float
  originLng       Float
  destAddress     String
  destLat         Float
  destLng         Float
  routeGeoJSON    Json?
  distanceMiles   Float
  etaMin          Int
  fareBase                Float
  farePerMile             Float
  fareTime                Float         @default(0)
  fareEwrSurcharge        Float         @default(0)
  fareTimeOfDaySurcharge  Float         @default(0)
  fareTollAmount          Float         @default(0)
  fareCrossingSurcharge   Float         @default(0)
  fareTotal               Float
  fareCurrency            String        @default("USD")
  paymentMethod   PaymentMethod
  paymentTiming   PaymentTiming
  paymentStatus   PaymentStatus @default(PENDING)
  stripeSessionId String?
  receiptBase64   String?
  state           TripState     @default(PENDING_PAYMENT)
  stateHistory    Json
  reminderSentAt  DateTime?
  driverConfirmToken String?
  driverConfirmedAt  DateTime?
  notifiedAt         DateTime?
  driverId        String?
  driver          Driver?       @relation(fields: [driverId], references: [id])
  consentLogs     ConsentLog[]
}
